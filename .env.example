# Copy this file to .env and fill in real local values.
# .env is ignored by Git and should never be committed.

SECRET_KEY=change-this-to-a-long-random-string
# For PythonAnywhere, either omit DATABASE_URL or use the absolute Linux path
# to the SQLite file that already has your user/family data. Common options:
# DATABASE_URL=sqlite:////home/your-username/your-project/vaultsync.db
# DATABASE_URL=sqlite:////home/your-username/your-project/instance/vaultsync.db
DATABASE_URL=sqlite:///vaultsync.db
FLASK_DEBUG=1
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000

# Google AI Studio / Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional switches
# RUN_AI_ORGANIZER_SCHEDULER=1
# DISABLE_AI_ORGANIZER_SCHEDULER=1
# DISABLE_DAILY_REPORT_SCHEDULER=1
# DISABLE_AI_PLAN_SCHEDULER=1
